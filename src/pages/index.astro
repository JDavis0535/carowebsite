---
import Layout from "../layouts/Layout.astro";
import ScarfCard from "../components/ScarfCard.astro";
import scarves from "../data/scarves.json";

const featured = scarves.filter((s) => s.inStock).slice(0, 3);
---

<Layout>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-5 pt-16 pb-20 grid lg:grid-cols-2 gap-12 items-center">
      <div class="rise">
        <span class="inline-block rounded-full bg-blush px-4 py-1.5 text-sm font-semibold text-terracotta-dark">
          Handmade in small batches
        </span>
        <h1 class="mt-5 font-display text-5xl sm:text-6xl font-semibold leading-[1.05] tracking-tight">
          Dapper scarves for <span class="text-terracotta">very good dogs</span>
        </h1>
        <p class="mt-5 text-lg text-ink-soft max-w-md leading-relaxed">
          Lovingly sewn, one at a time, from premium fabrics. Find the perfect
          piece for your pup — then send us a message to make it yours.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/store" class="inline-flex items-center rounded-full bg-terracotta px-6 py-3 font-semibold text-cream hover:bg-terracotta-dark transition-colors">
            Browse the collection
          </a>
          <a href="/about" class="inline-flex items-center rounded-full border border-ink/15 px-6 py-3 font-semibold text-ink hover:border-terracotta hover:text-terracotta transition-colors">
            Our story
          </a>
        </div>
      </div>

      <div class="rise relative">
        <div class="aspect-[4/5] overflow-hidden rounded-[2rem] bg-cream-deep shadow-lg rotate-2">
          <img src="https://placedog.net/700/900?id=10" alt="A happy dog wearing a handmade scarf" class="h-full w-full object-cover" />
        </div>
        <div class="absolute -bottom-5 -left-5 hidden sm:block aspect-square w-36 overflow-hidden rounded-2xl bg-cream-deep shadow-lg -rotate-3 ring-4 ring-cream">
          <img src="https://placedog.net/300/300?id=11" alt="Close-up of a dog scarf" class="h-full w-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust row -->
  <section class="border-y border-cream-deep bg-cream-deep/30">
    <div class="max-w-6xl mx-auto px-5 py-8 grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
      <div>
        <p class="font-display text-2xl font-semibold text-terracotta">100% handmade</p>
        <p class="text-sm text-ink-soft mt-1">Every scarf sewn by hand</p>
      </div>
      <div>
        <p class="font-display text-2xl font-semibold text-terracotta">Premium fabrics</p>
        <p class="text-sm text-ink-soft mt-1">Soft, durable, pup-approved</p>
      </div>
      <div>
        <p class="font-display text-2xl font-semibold text-terracotta">Made to order</p>
        <p class="text-sm text-ink-soft mt-1">Custom sizes on request</p>
      </div>
    </div>
  </section>

  <!-- Featured -->
  <section class="max-w-6xl mx-auto px-5 py-20">
    <div class="flex items-end justify-between gap-4">
      <div>
        <h2 class="font-display text-3xl sm:text-4xl font-semibold">This week's favourites</h2>
        <p class="mt-2 text-ink-soft">A few pieces fresh off the sewing table.</p>
      </div>
      <a href="/store" class="hidden sm:inline-flex shrink-0 font-semibold text-terracotta hover:text-terracotta-dark">
        View all →
      </a>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((scarf) => <ScarfCard scarf={scarf} />)}
    </div>

    <div class="mt-10 text-center sm:hidden">
      <a href="/store" class="inline-flex font-semibold text-terracotta">View all scarves →</a>
    </div>
  </section>

  <!-- CTA band -->
  <section class="max-w-6xl mx-auto px-5">
    <div class="rounded-3xl bg-terracotta px-8 py-14 text-center text-cream">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold">Found the one?</h2>
      <p class="mt-3 text-cream/90 max-w-lg mx-auto">
        Send us a quick message with the scarf you love and your dog's neck size —
        we'll sort out the rest.
      </p>
      <a href="/contact" class="mt-7 inline-flex items-center rounded-full bg-cream px-7 py-3 font-semibold text-terracotta-dark hover:bg-blush transition-colors">
        Get in touch
      </a>
    </div>
  </section>
</Layout>
