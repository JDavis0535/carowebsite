---
import Layout from "../layouts/Layout.astro";
import ScarfCard from "../components/ScarfCard.astro";
import { scarves } from "../lib/scarves";
---

<Layout title="Your favourites — Barker & Bow" description="The scarves you've saved.">
  <section class="max-w-6xl mx-auto px-5 pt-14 pb-6 text-center">
    <h1 class="font-display text-4xl sm:text-5xl font-semibold">Your favourites</h1>
    <p class="mt-4 text-ink-soft max-w-xl mx-auto">The scarves you've hearted — saved on this device.</p>
  </section>

  <section class="max-w-6xl mx-auto px-5 py-10">
    <div id="favs-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {scarves.map((s) => (
        <div data-scarf-id={s.id}><ScarfCard scarf={s} /></div>
      ))}
    </div>

    <div id="favs-empty" class="hidden py-16 text-center">
      <p class="text-ink-soft">You haven't saved any scarves yet.</p>
      <a href="/store" class="mt-5 inline-flex items-center rounded-full bg-terracotta px-6 py-3 font-semibold text-cream hover:bg-terracotta-dark transition-colors">
        Browse the collection
      </a>
    </div>
  </section>
</Layout>

<script>
  const read = () => {
    try { return JSON.parse(localStorage.getItem("bb-favs") || "[]"); } catch { return []; }
  };
  function filter() {
    const favs = read();
    let shown = 0;
    document.querySelectorAll("#favs-grid [data-scarf-id]").forEach((el) => {
      const on = favs.includes(el.dataset.scarfId);
      el.classList.toggle("hidden", !on);
      if (on) shown++;
    });
    document.getElementById("favs-grid")?.classList.toggle("hidden", shown === 0);
    document.getElementById("favs-empty")?.classList.toggle("hidden", shown !== 0);
  }
  window.addEventListener("favs:changed", filter);
  window.addEventListener("pageshow", filter);
  filter();
</script>
