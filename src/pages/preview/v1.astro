---
import "../../styles/global.css";
// DRAFT homepage direction A — "Warm Editorial". Not linked in nav.
const featured = [
  { name: "Autumn Plaid", img: "https://placedog.net/600/600?id=1" },
  { name: "Blush Floral", img: "https://placedog.net/600/600?id=3" },
  { name: "Forest Tartan", img: "https://placedog.net/600/600?id=6" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Draft A — Barker &amp; Bow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      body { font-family: "Inter", sans-serif; color: #2b2722; background: #fbf7f0; margin: 0; }
      .display { font-family: "Fraunces", serif; }
    </style>
  </head>
  <body>
    <!-- Announcement bar -->
    <div style="background:#c5694a;color:#fbf7f0" class="text-center text-sm font-semibold py-2 px-4">
      Handmade to order · Free shipping when you buy two or more 🐾
    </div>

    <!-- Header -->
    <header class="border-b" style="border-color:#f3ead9">
      <div class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between">
        <span class="display text-2xl font-semibold">Barker <span style="color:#c5694a">&amp;</span> Bow</span>
        <nav class="hidden sm:flex gap-7 text-sm font-medium" style="color:#5b5247">
          <span>Shop</span><span>About</span><span>Sizing</span><span>Contact</span>
        </nav>
        <span class="rounded-full px-5 py-2 text-sm font-semibold" style="background:#c5694a;color:#fbf7f0">Shop scarves</span>
      </div>
    </header>

    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-5 pt-14 pb-16 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-block rounded-full px-4 py-1.5 text-sm font-semibold" style="background:#f0d9c8;color:#a8553a">Handmade dog scarves</span>
        <h1 class="display mt-5 font-semibold leading-[0.98] tracking-tight" style="font-size:68px">
          Dress your dog.<br /><span style="color:#c5694a">Steal the show.</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed max-w-md" style="color:#5b5247">
          Small-batch scarves, sewn by hand in five sizes — from teacup pups to giant softies. Pick a print, choose a size, done.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <span class="rounded-full px-7 py-3.5 font-semibold" style="background:#c5694a;color:#fbf7f0">Shop the collection</span>
          <span class="rounded-full px-7 py-3.5 font-semibold border" style="border-color:#2b272233">How it works</span>
        </div>
        <div class="mt-7 flex items-center gap-2 text-sm" style="color:#5b5247">
          <span style="color:#c5694a">★★★★★</span> Loved by 500+ very good dogs
        </div>
      </div>
      <div class="relative">
        <div class="overflow-hidden rounded-[2rem] rotate-2" style="aspect-ratio:4/5;background:#f3ead9">
          <img src="https://placedog.net/720/900?id=10" class="w-full h-full object-cover" />
        </div>
        <div class="absolute -bottom-5 -left-5 rounded-2xl px-5 py-4 shadow-lg" style="background:#fbf7f0;border:4px solid #fbf7f0;box-shadow:0 10px 30px #2b272220">
          <p class="display text-2xl font-semibold" style="color:#c5694a">5 sizes</p>
          <p class="text-xs" style="color:#5b5247">tiny pups → giant breeds</p>
        </div>
      </div>
    </section>

    <!-- Value prop -->
    <section style="background:#f3ead9">
      <div class="max-w-6xl mx-auto px-5 py-14 text-center">
        <h2 class="display text-4xl font-semibold">Everything your dog needs. Nothing they don't.</h2>
        <div class="mt-10 grid sm:grid-cols-3 gap-8">
          <div><p class="display text-2xl font-semibold" style="color:#c5694a">Handmade</p><p class="mt-1 text-sm" style="color:#5b5247">Sewn one at a time, by hand</p></div>
          <div><p class="display text-2xl font-semibold" style="color:#c5694a">Premium fabrics</p><p class="mt-1 text-sm" style="color:#5b5247">Soft, durable, pup-approved</p></div>
          <div><p class="display text-2xl font-semibold" style="color:#c5694a">Five sizes</p><p class="mt-1 text-sm" style="color:#5b5247">A proper fit for every dog</p></div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="max-w-6xl mx-auto px-5 py-16">
      <h2 class="display text-4xl font-semibold text-center">How it works</h2>
      <div class="mt-10 grid sm:grid-cols-3 gap-8">
        {["Pick a design you love","Choose your dog's size","We handmake it and ship"].map((step, i) => (
          <div class="rounded-2xl p-6" style="background:#fff;border:1px solid #f3ead9">
            <div class="display text-3xl font-semibold" style="color:#c5694a">{i + 1}</div>
            <p class="mt-2 font-semibold">{step}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Testimonial -->
    <section class="max-w-3xl mx-auto px-5 py-12 text-center">
      <p style="color:#c5694a" class="text-lg">★★★★★</p>
      <p class="display text-3xl font-medium leading-snug mt-3">"The fit is perfect and the fabric is gorgeous. My whippet gets stopped on every walk."</p>
      <p class="mt-4 text-sm font-semibold" style="color:#5b5247">— Priya &amp; Biscuit</p>
    </section>

    <!-- Featured -->
    <section class="max-w-6xl mx-auto px-5 py-12">
      <div class="grid sm:grid-cols-3 gap-6">
        {featured.map((s) => (
          <div class="overflow-hidden rounded-2xl" style="background:#fff;border:1px solid #f3ead9">
            <img src={s.img} class="w-full object-cover" style="aspect-ratio:1" />
            <div class="p-4 flex items-center justify-between">
              <span class="display text-lg font-semibold">{s.name}</span>
              <span class="text-sm font-semibold" style="color:#c5694a">Shop →</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-6xl mx-auto px-5 pb-20">
      <div class="rounded-[2rem] px-8 py-16 text-center" style="background:#c5694a;color:#fbf7f0">
        <h2 class="display text-4xl font-semibold">Ready to spoil your pup?</h2>
        <p class="mt-3" style="color:#fbf7f0cc">Find their size and add a little handmade magic to every walk.</p>
        <span class="mt-7 inline-block rounded-full px-8 py-3.5 font-semibold" style="background:#fbf7f0;color:#a8553a">Shop the collection</span>
      </div>
    </section>
  </body>
</html>
