---
import Layout from "../layouts/Layout.astro";
import ScarfCard from "../components/ScarfCard.astro";
import { scarves } from "../lib/scarves";

const available = scarves.filter((s) => s.inStock);
const soldOut = scarves.filter((s) => !s.inStock);
---

<Layout title="Store — Barker & Bow" description="Browse our handmade dog scarves. Message us to order the one your dog loves.">
  <section class="max-w-6xl mx-auto px-5 pt-14 pb-6 text-center">
    <h1 class="font-display text-4xl sm:text-5xl font-semibold">The Collection</h1>
    <p class="mt-4 text-ink-soft max-w-xl mx-auto">
      Every design is handmade and comes in five sizes — from tiny pups to giant breeds.
      See one you love? Open it to pick a size, then
      <span class="font-semibold text-terracotta">message us to order</span>.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-5 py-10">
    <h2 class="sr-only">Available scarves</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {available.map((scarf) => <ScarfCard scarf={scarf} />)}
    </div>

    {soldOut.length > 0 && (
      <div class="mt-16">
        <h2 class="font-display text-2xl font-semibold text-ink-soft">Recently sold out</h2>
        <p class="text-sm text-ink-soft mt-1">Loved these too? Message us about a restock.</p>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 opacity-90">
          {soldOut.map((scarf) => <ScarfCard scarf={scarf} />)}
        </div>
      </div>
    )}
  </section>
</Layout>
