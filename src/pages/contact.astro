---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact — Barker & Bow" description="Message us about a scarf or a custom order.">
  <section class="max-w-3xl mx-auto px-5 pt-14 pb-6 text-center">
    <h1 class="font-display text-4xl sm:text-5xl font-semibold">Let's chat</h1>
    <p class="mt-4 text-ink-soft max-w-xl mx-auto">
      Tell us which scarf caught your eye (and your dog's neck measurement if you
      have it). We'll reply by email with availability and how to pay.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-5 pb-8 grid md:grid-cols-5 gap-8">
    <!-- Form -->
    <form
      name="scarf-inquiry"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="md:col-span-3 rounded-2xl bg-white p-6 sm:p-8 ring-1 ring-cream-deep space-y-5"
    >
      <input type="hidden" name="form-name" value="scarf-inquiry" />
      <p class="hidden">
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>

      <div>
        <label for="name" class="block text-sm font-semibold mb-1.5">Your name</label>
        <input id="name" name="name" type="text" required
          class="w-full rounded-lg border border-cream-deep bg-cream px-4 py-2.5 outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/30" />
      </div>

      <div>
        <label for="email" class="block text-sm font-semibold mb-1.5">Email</label>
        <input id="email" name="email" type="email" required
          class="w-full rounded-lg border border-cream-deep bg-cream px-4 py-2.5 outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/30" />
      </div>

      <div>
        <label for="scarf" class="block text-sm font-semibold mb-1.5">Scarf you're interested in</label>
        <input id="scarf" name="scarf" type="text" placeholder="e.g. Autumn Plaid (or 'a custom one!')"
          class="w-full rounded-lg border border-cream-deep bg-cream px-4 py-2.5 outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/30" />
      </div>

      <div>
        <label for="message" class="block text-sm font-semibold mb-1.5">Message</label>
        <textarea id="message" name="message" rows="4" required
          placeholder="Tell us about your dog and what you're after…"
          class="w-full rounded-lg border border-cream-deep bg-cream px-4 py-2.5 outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/30"></textarea>
      </div>

      <button type="submit"
        class="w-full inline-flex items-center justify-center rounded-full bg-terracotta px-6 py-3 font-semibold text-cream hover:bg-terracotta-dark transition-colors">
        Send message
      </button>
      <p class="text-xs text-ink-soft text-center">We usually reply within a day or two.</p>
    </form>

    <!-- Aside -->
    <aside class="md:col-span-2 space-y-6">
      <div class="rounded-2xl bg-blush/50 p-6">
        <h2 class="font-display text-xl font-semibold">Other ways to reach us</h2>
        <ul class="mt-3 space-y-2 text-sm text-ink-soft">
          <!-- TODO: Replace with your real details -->
          <li>📧 <a href="mailto:hello@barkerandbow.example" class="font-medium text-terracotta hover:underline">hello@barkerandbow.example</a></li>
          <li>📷 <a href="#" class="font-medium text-terracotta hover:underline">@barkerandbow</a> on Instagram</li>
        </ul>
      </div>
      <div class="rounded-2xl bg-white p-6 ring-1 ring-cream-deep">
        <h2 class="font-display text-xl font-semibold">Sizing tip</h2>
        <p class="mt-2 text-sm text-ink-soft leading-relaxed">
          Pop a soft tape measure around your dog's neck where a collar sits, then
          add a little room. Not sure? Send us the breed and we'll help.
        </p>
      </div>
    </aside>
  </section>
</Layout>

<script>
  // Prefill the "scarf" field from a ?scarf= link (e.g. from the store cards)
  const params = new URLSearchParams(window.location.search);
  const scarf = params.get("scarf");
  if (scarf) {
    const field = document.getElementById("scarf") as HTMLInputElement | null;
    if (field) field.value = scarf;
  }
</script>
