---
interface Props {
  scarf: {
    id: string;
    name: string;
    price: number;
    inStock: boolean;
    image: string;
    color?: string;
    material?: string;
    description?: string;
  };
}
const { scarf } = Astro.props;
const inquireHref = `/contact?scarf=${encodeURIComponent(scarf.name)}`;
---

<article class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-cream-deep hover:shadow-md transition-shadow">
  <div class="relative aspect-square overflow-hidden bg-cream-deep">
    <img
      src={scarf.image}
      alt={`${scarf.name} dog scarf`}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    {scarf.inStock ? (
      <span class="absolute left-3 top-3 rounded-full bg-sage/95 px-3 py-1 text-xs font-semibold text-white">
        In stock
      </span>
    ) : (
      <span class="absolute left-3 top-3 rounded-full bg-ink/80 px-3 py-1 text-xs font-semibold text-white">
        Sold out
      </span>
    )}
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-baseline justify-between gap-3">
      <h3 class="font-display text-xl font-semibold">{scarf.name}</h3>
      <span class="font-semibold text-terracotta">£{scarf.price}</span>
    </div>
    {scarf.color && (
      <p class="mt-1 text-sm text-ink-soft">{scarf.color} · {scarf.material}</p>
    )}
    {scarf.description && (
      <p class="mt-3 text-sm text-ink-soft leading-relaxed">{scarf.description}</p>
    )}

    <a
      href={inquireHref}
      class={`mt-5 inline-flex items-center justify-center rounded-full px-4 py-2.5 text-sm font-semibold transition-colors ${
        scarf.inStock
          ? "bg-terracotta text-cream hover:bg-terracotta-dark"
          : "bg-cream-deep text-ink-soft hover:bg-blush"
      }`}
    >
      {scarf.inStock ? "Message to order" : "Ask about restock"}
    </a>
  </div>
</article>
