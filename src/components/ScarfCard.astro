---
import type { Scarf } from "../lib/scarves";

interface Props {
  scarf: Scarf;
}
const { scarf } = Astro.props;
const href = `/scarves/${scarf.id}`;
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-cream-deep hover:shadow-md transition-shadow"
>
  <div class="relative aspect-square overflow-hidden bg-cream-deep">
    <img
      src={scarf.image}
      alt={`${scarf.name} dog scarf`}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    {scarf.inStock ? (
      <span class="absolute left-3 top-3 rounded-full bg-sage/95 px-3 py-1 text-xs font-semibold text-white">
        In stock
      </span>
    ) : (
      <span class="absolute left-3 top-3 rounded-full bg-ink/80 px-3 py-1 text-xs font-semibold text-white">
        Sold out
      </span>
    )}
  </div>

  <div class="flex flex-1 flex-col p-5">
    <h3 class="font-display text-xl font-semibold">{scarf.name}</h3>
    {scarf.color && (
      <p class="mt-1 text-sm text-ink-soft">{scarf.color}</p>
    )}
    {scarf.description && (
      <p class="mt-3 text-sm text-ink-soft leading-relaxed line-clamp-2">{scarf.description}</p>
    )}

    <span class="mt-5 inline-flex items-center justify-center rounded-full bg-terracotta px-4 py-2.5 text-sm font-semibold text-cream group-hover:bg-terracotta-dark transition-colors">
      View details
    </span>
  </div>
</a>
