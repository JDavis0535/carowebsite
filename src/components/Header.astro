---
const links = [
  { href: "/", label: "Home" },
  { href: "/store", label: "Store" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-50 backdrop-blur bg-cream/85 border-b border-cream-deep">
  <nav class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between">
    <a href="/" class="font-display text-2xl font-semibold text-ink tracking-tight">
      Barker <span class="text-terracotta">&amp;</span> Bow
    </a>

    <!-- Desktop nav -->
    <ul class="hidden sm:flex items-center gap-7 text-sm font-medium">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class={`transition-colors hover:text-terracotta ${
              isActive(l.href) ? "text-terracotta" : "text-ink-soft"
            }`}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-1 sm:gap-2">
      <!-- Favourites -->
      <a href="/favourites" aria-label="Favourites" class="relative p-2 text-ink hover:text-terracotta transition-colors">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54z" />
        </svg>
        <span data-fav-count class="hidden absolute -right-0.5 -top-0.5 min-w-[18px] rounded-full bg-terracotta px-1 text-center text-[11px] font-bold leading-[18px] text-cream">0</span>
      </a>

      <!-- Cart -->
      <button type="button" data-cart-toggle aria-label="Open cart" class="relative p-2 text-ink hover:text-terracotta transition-colors">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
          <path d="M3 6h18" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span data-cart-count class="hidden absolute -right-0.5 -top-0.5 min-w-[18px] rounded-full bg-terracotta px-1 text-center text-[11px] font-bold leading-[18px] text-cream">0</span>
      </button>

      <a
        href="/contact"
        class="hidden sm:inline-flex items-center rounded-full bg-terracotta px-4 py-2 text-sm font-semibold text-cream hover:bg-terracotta-dark transition-colors"
      >
        Message us
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="menu-toggle"
        class="sm:hidden p-2 text-ink"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-cream-deep bg-cream">
    <ul class="px-5 py-3 space-y-1">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class={`block rounded-lg px-3 py-2 font-medium ${
              isActive(l.href) ? "bg-blush text-terracotta-dark" : "text-ink-soft"
            }`}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(open));
  });
</script>
