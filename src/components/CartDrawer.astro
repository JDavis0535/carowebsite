---
// Global shopping cart: slide-out drawer + all cart logic.
// Exposes window.cart.add(item) for "Add to cart" buttons.
---

<!-- Backdrop -->
<div id="cart-backdrop" class="fixed inset-0 z-[55] hidden bg-ink/50"></div>

<!-- Drawer -->
<aside
  id="cart-drawer"
  class="fixed right-0 top-0 z-[60] flex h-full w-full max-w-sm translate-x-full flex-col bg-cream shadow-2xl transition-transform duration-300"
  aria-label="Shopping cart"
>
  <div class="flex items-center justify-between border-b border-cream-deep px-5 py-4">
    <h2 class="font-display text-xl font-semibold">Your cart</h2>
    <button type="button" data-cart-close aria-label="Close cart" class="text-2xl leading-none text-ink-soft hover:text-ink">×</button>
  </div>

  <ul id="cart-items" class="flex-1 divide-y divide-cream-deep overflow-y-auto px-5"></ul>

  <p id="cart-empty" class="flex-1 px-5 py-12 text-center text-ink-soft">
    Your cart is empty.<br />
    <a href="/store" data-cart-close class="mt-2 inline-block font-semibold text-terracotta hover:underline">Browse the collection →</a>
  </p>

  <div class="border-t border-cream-deep px-5 py-4">
    <div class="flex items-center justify-between">
      <span class="text-sm text-ink-soft">Subtotal</span>
      <span id="cart-subtotal" class="font-display text-xl font-semibold">$0.00</span>
    </div>
    <p class="mt-1 text-xs text-ink-soft">Shipping calculated at checkout.</p>
    <button
      id="cart-checkout"
      type="button"
      disabled
      class="mt-4 w-full rounded-full bg-terracotta px-6 py-3 font-semibold text-cream transition-colors hover:bg-terracotta-dark disabled:cursor-not-allowed disabled:opacity-50"
    >
      Checkout
    </button>
  </div>
</aside>

<script>
  const KEY = "bb-cart";
  const read = () => {
    try { return JSON.parse(localStorage.getItem(KEY) || "[]"); } catch { return []; }
  };
  const write = (c) => { localStorage.setItem(KEY, JSON.stringify(c)); render(); };
  const money = (n) => "$" + n.toFixed(2);
  const keyOf = (i) => i.id + "||" + (i.size || "");

  const drawer = document.getElementById("cart-drawer");
  const backdrop = document.getElementById("cart-backdrop");
  const itemsEl = document.getElementById("cart-items");
  const emptyEl = document.getElementById("cart-empty");
  const subtotalEl = document.getElementById("cart-subtotal");
  const checkoutBtn = document.getElementById("cart-checkout");

  function open() {
    drawer?.classList.remove("translate-x-full");
    backdrop?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }
  function close() {
    drawer?.classList.add("translate-x-full");
    backdrop?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  function add(item) {
    const cart = read();
    const k = keyOf(item);
    const existing = cart.find((i) => keyOf(i) === k);
    if (existing) existing.qty += item.qty || 1;
    else cart.push({
      id: item.id, name: item.name, size: item.size || "",
      price: Number(item.price), image: item.image || "", qty: item.qty || 1,
    });
    write(cart);
  }

  function render() {
    const cart = read();
    const totalQty = cart.reduce((n, i) => n + i.qty, 0);
    document.querySelectorAll("[data-cart-count]").forEach((el) => {
      el.textContent = String(totalQty);
      el.classList.toggle("hidden", totalQty === 0);
    });
    if (!itemsEl) return;

    if (cart.length === 0) {
      itemsEl.innerHTML = "";
      itemsEl.classList.add("hidden");
      emptyEl?.classList.remove("hidden");
      checkoutBtn?.setAttribute("disabled", "");
    } else {
      itemsEl.classList.remove("hidden");
      emptyEl?.classList.add("hidden");
      checkoutBtn?.removeAttribute("disabled");
      itemsEl.innerHTML = cart.map((i, idx) => `
        <li class="flex gap-3 py-4">
          <img src="${i.image}" alt="" class="h-16 w-16 shrink-0 rounded-lg bg-cream-deep object-cover" />
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-ink">${i.name}</p>
            ${i.size ? `<p class="text-xs text-ink-soft">${i.size}</p>` : ""}
            <p class="mt-0.5 text-sm font-semibold text-terracotta">${money(i.price)}</p>
            <div class="mt-2 flex items-center gap-2">
              <button data-dec="${idx}" aria-label="Decrease quantity" class="h-6 w-6 rounded border border-cream-deep leading-none hover:bg-cream-deep">−</button>
              <span class="w-6 text-center text-sm">${i.qty}</span>
              <button data-inc="${idx}" aria-label="Increase quantity" class="h-6 w-6 rounded border border-cream-deep leading-none hover:bg-cream-deep">+</button>
              <button data-remove="${idx}" class="ml-auto text-xs text-ink-soft underline hover:text-terracotta">Remove</button>
            </div>
          </div>
        </li>`).join("");
    }
    const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
    if (subtotalEl) subtotalEl.textContent = money(subtotal);
  }

  itemsEl?.addEventListener("click", (e) => {
    const t = e.target.closest("[data-dec],[data-inc],[data-remove]");
    if (!t) return;
    const cart = read();
    if (t.hasAttribute("data-dec")) {
      const i = +t.dataset.dec; cart[i].qty--; if (cart[i].qty <= 0) cart.splice(i, 1);
    } else if (t.hasAttribute("data-inc")) {
      cart[+t.dataset.inc].qty++;
    } else if (t.hasAttribute("data-remove")) {
      cart.splice(+t.dataset.remove, 1);
    }
    write(cart);
  });

  document.querySelectorAll("[data-cart-toggle]").forEach((b) => b.addEventListener("click", open));
  document.querySelectorAll("[data-cart-close]").forEach((b) => b.addEventListener("click", close));
  backdrop?.addEventListener("click", close);
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });

  checkoutBtn?.addEventListener("click", async () => {
    const cart = read();
    if (!cart.length) return;
    checkoutBtn.setAttribute("disabled", "");
    checkoutBtn.textContent = "Starting checkout…";
    try {
      const res = await fetch("/.netlify/functions/create-checkout", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ items: cart.map((i) => ({ id: i.id, size: i.size, qty: i.qty })) }),
      });
      const data = await res.json();
      if (data.url) { window.location.href = data.url; return; }
      alert(data.error || "Checkout isn't available yet.");
    } catch {
      alert("Something went wrong starting checkout. Please try again.");
    }
    checkoutBtn.removeAttribute("disabled");
    checkoutBtn.textContent = "Checkout";
  });

  // Public API for "Add to cart" buttons and the success page
  window.cart = { add: (item) => { add(item); open(); }, open, close, clear: () => write([]) };

  render();
</script>
